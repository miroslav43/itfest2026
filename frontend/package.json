{
  "name": "solemtrix-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:mobile": "BUILD_TARGET=mobile next build",
    "start": "next start",
    "lint": "next lint",
    "cap:sync": "npm run build:mobile && npx cap sync android",
    "cap:sync:local": "NEXT_PUBLIC_API_URL=http://$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1):8000 BUILD_TARGET=mobile next build && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:run": "npm run build:mobile && npx cap sync android && npx cap run android",
    "cap:run:local": "npm run cap:sync:local && npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@picovoice/porcupine-web": "^4.0.0",
    "@picovoice/web-voice-processor": "^4.0.9",
    "@react-google-maps/api": "^2.20.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
